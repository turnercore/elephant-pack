{
  "name": "elephant-pack",
  "version": "0.5.5",
  "private": true,
  "type": "module",
  "description": "Browser extension that packages GitHub and Forgejo repositories into ChatGPT-ready source context bundles.",
  "scripts": {
    "prebuild": "node scripts/generate-icons.mjs",
    "build": "tsc --noEmit && vite build",
    "build:safari": "npm run build && node scripts/prepare-safari-dist.mjs",
    "package:safari": "npm run build:safari && node scripts/package-safari.mjs",
    "test": "vitest run",
    "dev": "vite build --watch"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.0",
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
